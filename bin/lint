#!/bin/bash
set -exu

# If CI is unset or empty, use true as the default value
CI="${CI:-true}"

cd "$(dirname "$0")"/..

LINT="toolkit tests"
EXCLUDE_IPYNB_REGEX='\.ipynb$'
EXCLUDE_IPYNB_GLOB='*.ipynb'

# Run mypy for type checking
mypy --exclude "${EXCLUDE_IPYNB_REGEX}" ${LINT}

if [ "${CI}" = true ]; then
    # In CI, only check code formatting and linting with Ruff
    black --check --extend-exclude "${EXCLUDE_IPYNB_REGEX}" ${LINT}
    ruff check --extend-exclude "${EXCLUDE_IPYNB_GLOB}" ${LINT}
    uv run black --check --extend-exclude "${EXCLUDE_IPYNB_REGEX}" .
else
    # Locally, automatically fix formatting issues with Ruff
    black --extend-exclude "${EXCLUDE_IPYNB_REGEX}" ${LINT}
    uv run black --extend-exclude "${EXCLUDE_IPYNB_REGEX}" .
    ruff check --fix --extend-exclude "${EXCLUDE_IPYNB_GLOB}" ${LINT}
fi